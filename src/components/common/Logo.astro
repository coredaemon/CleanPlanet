---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<a href="/" class="inline-flex items-center gap-3" aria-label="CleanPlanet на главную">
  {
    compact ? (
      <img src="/logo-mark.png" alt="" width="42" height="42" class="h-10 w-10 object-contain" />
    ) : (
      <picture>
        <source media="(max-width: 767px)" srcset="/logo-mark.png" />
        <img
          src="/logo-full-cropped.png"
          alt="CleanPlanet"
          width="220"
          height="64"
          class="h-14 w-auto object-contain"
        />
      </picture>
    )
  }
</a>
