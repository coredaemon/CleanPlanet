---
import { contacts } from '@/data/contacts';
---

<nav
  class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-3 border-t border-border bg-white text-xs font-semibold text-primary-dark shadow-lg md:hidden"
  aria-label="Быстрые действия"
>
  <a
    class="flex min-h-[64px] flex-col items-center justify-center gap-1"
    href={contacts.phoneHref}
    data-track="phone_click"
  >
    <span class="h-2 w-2 rounded-full bg-primary" aria-hidden="true"></span>
    Позвонить
  </a>
  <a
    class="flex min-h-[64px] flex-col items-center justify-center gap-1 border-x border-border"
    href={contacts.whatsappHref}
    data-track="messenger_click"
  >
    <span class="h-2 w-2 rounded-full bg-accent" aria-hidden="true"></span>
    Написать
  </a>
  <button
    class="flex min-h-[64px] flex-col items-center justify-center gap-1 bg-[var(--color-accent-soft)]"
    type="button"
    data-track="calculator_start"
    data-open-lead
  >
    <span class="h-2 w-2 rounded-full bg-primary-dark" aria-hidden="true"></span>
    Рассчитать
  </button>
</nav>
