---
const items = [
  {
    title: 'Опыт и объём',
    text: 'Более 8 лет в клининге и свыше 10 000 выполненных заказов.',
    icon: `<path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>`,
  },
  {
    title: 'Проверенные исполнители',
    text: 'Опытные клинеры с профессиональным инвентарём и оборудованием.',
    icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="m17 11 2 2 4-4"/>`,
  },
  {
    title: 'Договор и документы',
    text: 'Работаем с частными лицами и организациями, оформляем закрывающие документы.',
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h8"/>`,
  },
  {
    title: 'Гарантия и ответственность',
    text: 'Устраняем замечания по гарантии и отвечаем за сохранность имущества.',
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
  },
  {
    title: 'Оценка по фотографиям',
    text: 'Пришлите фото объекта — подготовим предварительный расчёт до выезда.',
    icon: `<rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/>`,
  },
  {
    title: 'Удобный формат',
    text: 'Разовая уборка или регулярный график. Возможен выезд в день обращения.',
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
];
---

<section class="py-14 md:py-20">
  <div class="container">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-wide text-accent">Почему выбирают нас</p>
      <h2
        class="mt-2 text-3xl font-bold leading-tight text-[var(--color-text-heading)] md:text-4xl"
      >
        Надёжный сервис уборки, которому доверяют
      </h2>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map((item) => (
          <div class="rounded-large border border-border bg-white p-6 transition hover:border-[var(--color-border-strong)] hover:shadow-sm">
            <span
              class="inline-flex h-12 w-12 items-center justify-center rounded-medium bg-[var(--color-accent-soft)] text-primary"
              aria-hidden="true"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={item.icon}
              />
            </span>
            <h3 class="mt-4 text-lg font-bold text-[var(--color-text-heading)]">{item.title}</h3>
            <p class="mt-2 text-sm text-muted">{item.text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
