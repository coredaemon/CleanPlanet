---
const badges = [
  {
    title: 'Договор и документы',
    text: 'Работаем по договору с частными лицами и организациями',
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h8"/>`,
  },
  {
    title: 'Переделаем по гарантии',
    text: 'Если по уборке есть замечания — устраним по гарантии',
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>`,
  },
  {
    title: 'Профессиональные средства',
    text: 'Свой инвентарь и оборудование — покупать ничего не нужно',
    icon: `<path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/><path d="M9 9v.01"/><path d="M9 12v.01"/><path d="M9 15v.01"/>`,
  },
  {
    title: 'Оплата после уборки',
    text: 'Переводом, через СБП или по счёту — после выполнения работ',
    icon: `<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>`,
  },
  {
    title: 'Круглосуточно',
    text: 'Принимаем заявки круглосуточно и без выходных',
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
];
---

<section class="border-y border-border bg-white">
  <div class="container grid gap-x-6 gap-y-6 py-8 sm:grid-cols-2 lg:grid-cols-5 lg:py-10">
    {
      badges.map((b) => (
        <div class="flex items-start gap-3">
          <span
            class="mt-0.5 inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-medium bg-[var(--color-accent-soft)] text-primary"
            aria-hidden="true"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={b.icon}
            />
          </span>
          <div>
            <p class="font-bold leading-tight text-[var(--color-text-heading)]">{b.title}</p>
            <p class="mt-1 text-sm text-muted">{b.text}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
