---
import type { Service } from '@/data/services';

interface Props {
  services: Service[];
  title?: string;
  lead?: string;
}

const {
  services,
  title = 'Услуги',
  lead = 'Выберите подходящее направление и перейдите на страницу услуги.',
} = Astro.props as Props;
---

<section class="py-14 md:py-20">
  <div class="container">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-bold leading-tight text-[var(--color-text-heading)] md:text-4xl">
        {title}
      </h2>
      <p class="mt-3 text-lg text-muted">{lead}</p>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <article class="relative flex flex-col rounded-large border border-border bg-white p-5 transition hover:-translate-y-1 hover:border-[var(--color-border-strong)] hover:shadow-sm">
            {service.featured && (
              <span class="absolute right-4 top-4 rounded-pill bg-[var(--color-accent-soft)] px-3 py-1 text-xs font-bold text-primary">
                Популярное
              </span>
            )}
            <div
              class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-medium bg-[var(--color-accent-soft)] text-primary"
              aria-hidden="true"
            >
              <span class="h-4 w-4 rounded-full border-2 border-current" />
            </div>
            <h3 class="text-xl font-bold leading-tight text-[var(--color-text-heading)]">
              <a class="hover:text-primary" href={`/services/${service.slug}/`}>
                {service.shortTitle}
              </a>
            </h3>
            <p class="mt-3 text-sm text-muted">{service.description}</p>
            <p class="mt-auto pt-4 text-sm font-bold text-primary">от 5 000 ₽</p>
            <div class="mt-3 flex gap-2">
              <button
                class="inline-flex min-h-11 flex-1 items-center justify-center rounded-medium bg-primary px-4 text-sm font-semibold text-white transition hover:bg-primary-hover"
                type="button"
                data-open-lead
                data-service={service.shortTitle}
              >
                Заказать
              </button>
              <a
                class="inline-flex min-h-11 items-center justify-center rounded-medium border border-border px-4 text-sm font-semibold text-primary-dark transition hover:bg-[var(--color-surface-hover)]"
                href={`/services/${service.slug}/`}
              >
                Подробнее
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
