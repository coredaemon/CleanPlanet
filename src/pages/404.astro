---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Страница не найдена | CleanPlanet"
  description="Такой страницы на сайте CleanPlanet нет."
  noindex
>
  <section class="container py-20 text-center">
    <p class="text-sm font-bold uppercase tracking-[0.1em] text-primary">404</p>
    <h1 class="mt-3 text-[clamp(2rem,6vw,3.5rem)] font-bold text-[var(--color-text-heading)]">
      Страница не найдена
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-muted">
      Перейдите в каталог услуг или оставьте заявку, если искали конкретный вид уборки.
    </p>
    <a
      class="mt-8 inline-flex min-h-12 items-center justify-center rounded-medium bg-primary px-5 font-semibold text-white"
      href="/services/">Перейти к услугам</a
    >
  </section>
</BaseLayout>
