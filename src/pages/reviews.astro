---
import Breadcrumbs from '@/components/common/Breadcrumbs.astro';
import LeadForm from '@/components/forms/LeadForm.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import reviewsData from '@/data/reviews.json';

const reviews = reviewsData as { src: string; width: number; height: number; alt: string }[];
---

<BaseLayout
  title="Отзывы клиентов | CleanPlanet"
  description="Реальные отзывы клиентов CleanPlanet — скриншоты переписок об уборке квартир, мытье окон и химчистке."
  canonical="/reviews/"
>
  <Breadcrumbs items={[{ label: 'Отзывы', href: '/reviews/' }]} />
  <section class="container py-12 md:py-16">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-wide text-accent">Отзывы</p>
        <h1
          class="mt-2 text-[clamp(2rem,6vw,3.5rem)] font-bold leading-tight text-[var(--color-text-heading)]"
        >
          Что говорят клиенты
        </h1>
        <p class="mt-3 text-lg text-muted">
          Реальные сообщения после уборки — публикуются с согласия клиентов. Имена и личные данные
          скрыты. Листайте ленту или нажмите на отзыв, чтобы увеличить.
        </p>
      </div>
      <div class="hidden gap-2 md:flex">
        <button class="rv-nav" type="button" data-rv-prev aria-label="Предыдущие отзывы">‹</button>
        <button class="rv-nav" type="button" data-rv-next aria-label="Следующие отзывы">›</button>
      </div>
    </div>

    <div class="rv-track mt-8" data-rv-track>
      {
        reviews.map((item, i) => (
          <button
            class="rv-card"
            type="button"
            data-review-index={i}
            aria-label={`Открыть отзыв ${i + 1} крупнее`}
          >
            <img
              src={item.src}
              width={item.width}
              height={item.height}
              alt={item.alt}
              loading={i < 3 ? 'eager' : 'lazy'}
              decoding="async"
              draggable="false"
            />
          </button>
        ))
      }
    </div>
  </section>

  <section class="container py-14 md:py-20">
    <LeadForm title="Оставить заявку на уборку" />
  </section>

  <!-- Lightbox -->
  <div
    id="review-lightbox"
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 p-4"
    role="dialog"
    aria-modal="true"
    aria-label="Просмотр отзыва"
  >
    <button
      id="lightbox-close"
      class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-pill bg-white/90 text-2xl font-bold text-primary-dark"
      type="button"
      aria-label="Закрыть">×</button
    >
    <button
      id="lightbox-prev"
      class="absolute bottom-4 left-[calc(50%-4rem)] flex h-12 w-12 items-center justify-center rounded-pill bg-white/90 text-2xl font-bold text-primary-dark md:bottom-auto md:left-8"
      type="button"
      aria-label="Предыдущий отзыв">‹</button
    >
    <img
      id="lightbox-img"
      class="max-h-[88vh] max-w-full rounded-large object-contain shadow-lg"
      src=""
      alt=""
    />
    <button
      id="lightbox-next"
      class="absolute bottom-4 right-[calc(50%-4rem)] flex h-12 w-12 items-center justify-center rounded-pill bg-white/90 text-2xl font-bold text-primary-dark md:bottom-auto md:right-8"
      type="button"
      aria-label="Следующий отзыв">›</button
    >
  </div>
</BaseLayout>

<style>
  .rv-nav {
    display: flex;
    height: 44px;
    width: 44px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    background: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    transition: background 0.15s;
  }
  .rv-nav:hover {
    background: var(--color-surface-hover);
  }
  .rv-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding-bottom: 10px;
    scrollbar-width: thin;
  }
  .rv-card {
    flex: 0 0 auto;
    height: 440px;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-large);
    background: #fff;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    scroll-snap-align: start;
    cursor: pointer;
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .rv-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .rv-card:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
  .rv-card img {
    display: block;
    height: 100%;
    width: auto;
    max-width: none;
  }
  @media (max-width: 640px) {
    .rv-card {
      height: 380px;
    }
  }
</style>

<script is:inline define:vars={{ reviews }}>
  // Lightbox
  const lightbox = document.getElementById('review-lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  let current = 0;
  let touchStartX = 0;
  let touchStartY = 0;
  const show = (i) => {
    current = (i + reviews.length) % reviews.length;
    lightboxImg.src = reviews[current].src;
    lightboxImg.alt = reviews[current].alt;
  };
  const open = (i) => {
    show(i);
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
    stopAuto();
  };
  const close = () => {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  };
  document.querySelectorAll('[data-review-index]').forEach((btn) => {
    btn.addEventListener('click', () => open(Number(btn.dataset.reviewIndex)));
  });
  document.getElementById('lightbox-close').addEventListener('click', close);
  document.getElementById('lightbox-prev').addEventListener('click', () => show(current - 1));
  document.getElementById('lightbox-next').addEventListener('click', () => show(current + 1));
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });
  lightbox.addEventListener(
    'touchstart',
    (e) => {
      const touch = e.changedTouches[0];
      touchStartX = touch.clientX;
      touchStartY = touch.clientY;
    },
    { passive: true },
  );
  lightbox.addEventListener(
    'touchend',
    (e) => {
      const touch = e.changedTouches[0];
      const diffX = touch.clientX - touchStartX;
      const diffY = touch.clientY - touchStartY;
      if (Math.abs(diffX) <= 40 || Math.abs(diffX) < Math.abs(diffY)) return;
      show(diffX < 0 ? current + 1 : current - 1);
    },
    { passive: true },
  );
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });

  // Carousel
  const track = document.querySelector('[data-rv-track]');
  const step = () => (track.querySelector('.rv-card')?.getBoundingClientRect().width || 300) + 20;
  document
    .querySelector('[data-rv-prev]')
    ?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
  document
    .querySelector('[data-rv-next]')
    ?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));

  // Gentle autoplay (respects reduced-motion, pauses on interaction)
  let auto = null;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function stopAuto() {
    if (auto) {
      clearInterval(auto);
      auto = null;
    }
  }
  function startAuto() {
    if (reduce || auto) return;
    auto = setInterval(() => {
      const atEnd = track.scrollLeft + track.clientWidth >= track.scrollWidth - 5;
      if (atEnd) track.scrollTo({ left: 0, behavior: 'smooth' });
      else track.scrollBy({ left: step(), behavior: 'smooth' });
    }, 4000);
  }
  ['pointerdown', 'mouseenter', 'touchstart', 'focusin'].forEach((ev) =>
    track.addEventListener(ev, stopAuto, { passive: true }),
  );
  track.addEventListener('mouseleave', startAuto);
  startAuto();
</script>
