---
import { getCollection } from 'astro:content';
import Calculator from '@/components/calculator/Calculator.astro';
import LeadForm from '@/components/forms/LeadForm.astro';
import Hero from '@/components/sections/Hero.astro';
import InfoSections from '@/components/sections/InfoSections.astro';
import Faq from '@/components/sections/Faq.astro';
import ProjectsPreview from '@/components/sections/ProjectsPreview.astro';
import ServiceCards from '@/components/sections/ServiceCards.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { businessServices, featuredServices, homeServices } from '@/data/services';

const pages = await getCollection('pages');
const page = pages.find((entry) => entry.data.pageType === 'home');
if (!page) throw new Error('Home content not found');
const { Content } = await page.render();
---

<BaseLayout
  title={`${page.data.title} | CleanPlanet`}
  description={page.data.description}
  canonical="/"
>
  <Hero title="Уборка квартир, домов и помещений в Москве" description={page.data.description} />
  <section class="container py-12">
    <div class="prose-clean max-w-4xl">
      <Content />
    </div>
  </section>
  <ServiceCards
    services={featuredServices}
    title="Быстрый выбор услуги"
    lead="Самые востребованные направления для квартир, домов и коммерческих помещений."
  />
  <section class="container py-10">
    <Calculator />
  </section>
  <section class="py-14 md:py-20">
    <div class="container grid gap-6 md:grid-cols-2">
      <div class="rounded-xl bg-[var(--color-background-alt)] p-6">
        <h2 class="text-3xl font-bold text-[var(--color-text-heading)]">Уборка для дома</h2>
        <p class="mt-3 text-muted">
          Квартиры, дома, коттеджи, регулярная уборка и клининг после ремонта.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            homeServices.slice(0, 6).map((s) => (
              <a
                class="rounded-pill bg-white px-4 py-2 text-sm font-semibold text-primary shadow-sm"
                href={`/services/${s.slug}/`}
              >
                {s.shortTitle}
              </a>
            ))
          }
        </div>
      </div>
      <div class="rounded-xl bg-[var(--color-primary-dark)] p-6 text-white">
        <h2 class="text-3xl font-bold">Уборка для бизнеса</h2>
        <p class="mt-3 text-white/75">
          Офисы, магазины, салоны, кафе, спортивные залы и витринное остекление.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            businessServices.slice(0, 6).map((s) => (
              <a
                class="rounded-pill bg-white/12 px-4 py-2 text-sm font-semibold text-white"
                href={`/services/${s.slug}/`}
              >
                {s.shortTitle}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
  <InfoSections />
  <ProjectsPreview />
  <Faq />
  <section id="photo-form" class="container py-14 md:py-20">
    <LeadForm title="Оценка стоимости по фотографиям" formType="photo" />
  </section>
  <section class="container pb-20">
    <LeadForm title="Получить предварительный расчёт" />
  </section>
</BaseLayout>
